datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

enum Role {
  ADMIN
  CUSTOMER
}

enum LedgerType {
  PRODUCT
  PAYMENT
  ADJUSTMENT
}

model User {
  id                    String    @id @default(uuid())
  email                 String    @unique
  username              String    @unique
  name                  String?
  password              String
  role                  Role      @default(CUSTOMER)
  is_active             Boolean   @default(true)
  gender                String?
  phone                 String?
  avatar_url            String?
  assigned_customer_ids String[]  @default([])
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  deleted_at            DateTime?

  @@index([created_at])
}

model Customer {
  id            String          @id @default(uuid())
  customer_code String          @unique
  name          String
  avatar_url    String?
  created_at    DateTime        @default(now())
  deleted_at    DateTime?
  daily_items   DailyBookItem[]
  ledger_items  Ledger[]

  @@index([customer_code])
  @@index([created_at])
}

model DailyBook {
  id         String          @id @default(uuid())
  date       DateTime        @unique @db.Date
  is_closed  Boolean         @default(false)
  created_at DateTime        @default(now())
  deleted_at DateTime?
  items      DailyBookItem[]

  @@index([date])
}

model DailyBookItem {
  id            String    @id @default(uuid())
  daily_book_id String
  daily_book    DailyBook @relation(fields: [daily_book_id], references: [id])
  customer_id   String
  customer      Customer  @relation(fields: [customer_id], references: [id])
  kg            Float
  present       Boolean   @default(true)
  note          String?
  deleted_at    DateTime?

  @@index([daily_book_id])
  @@index([customer_id])
}

model Ledger {
  id             String     @id @default(uuid())
  customer_id    String
  customer       Customer   @relation(fields: [customer_id], references: [id])
  type           LedgerType
  reference_date DateTime?  @db.Date
  kg             Float?
  price_per_kg   Float?
  amount         Float
  previous_debt  Float
  new_debt       Float
  note           String?
  receipt_id     String?
  maqal_id       Int?
  created_at     DateTime   @default(now())
  deleted_at     DateTime?

  @@index([customer_id])
  @@index([type])
  @@index([reference_date])
  @@index([created_at])
}

model AdminSession {
  id           String   @id @default(uuid()) @db.Uuid
  user_id      String
  username     String
  name         String?
  role         String
  token        String   @unique
  login_at     DateTime @default(now())
  last_seen_at DateTime @default(now())
  expires_at   DateTime
  ip_address   String?
  user_agent   String?
  avatar_url   String?

  @@index([token])
  @@index([username])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String?
  username   String
  name       String?
  role       String
  action     String
  details    String
  ip_address String?
  user_agent String?
  created_at DateTime @default(now())

  @@index([username])
  @@index([action])
  @@index([created_at])
}
